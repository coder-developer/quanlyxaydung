{
  "name": "quan-ly-xay-dung",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm run build",
    "desktop:build": "electron-builder --win portable"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "firebase": "^12.16.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.2",
    "tsx": "^4.21.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.5",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "main": "desktop/main.cjs",
  "build": {
    "appId": "vn.constructos.erp",
    "productName": "Quản trị doanh nghiệp",
    "files": [
      "desktop/**/*"
    ],
    "win": {
      "target": "portable",
      "artifactName": "Quan-Tri-Doanh-Nghiep-Windows-${version}.exe"
    },
    "directories": {
      "output": "release/windows"
    }
  }
}
