# Firebase Authentication chỉ phục vụ đăng nhập Google Drive; không dùng Firestore lưu ERP.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Chế độ VPS dùng PostgreSQL/API tập trung
VITE_USE_SERVER="true"
PORT="8080"
APP_BIND="127.0.0.1"
DOMAIN="erp.tencongty.vn"
ACME_EMAIL="admin@tencongty.vn"
DATABASE_URL="postgresql://constructos:CHANGE_ME@postgres:5432/constructos"
DATABASE_SSL="false"
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS"
SEED_CEO_PIN="CHANGE_ME"
SEED_ACCOUNTANT_PIN="CHANGE_ME"
SEED_SITE_MANAGER_PIN="CHANGE_ME"
SEED_AUDITOR_PIN="CHANGE_ME"
SEED_EMPLOYEE_PIN="CHANGE_ME"
OTP_WEBHOOK_URL=""
OTP_WEBHOOK_TOKEN=""
# Ví dụ rclone: "remote-secure:quan-tri-doanh-nghiep/backups"
BACKUP_REMOTE=""
