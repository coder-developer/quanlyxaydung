# Firebase (tùy chọn). Nếu bỏ trống, app dùng cấu hình trong
# firebase-applet-config.json và dữ liệu vẫn được lưu trên trình duyệt.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Chế độ VPS dùng PostgreSQL/API tập trung
VITE_USE_SERVER="true"
PORT="8080"
DATABASE_URL="postgresql://constructos:CHANGE_ME@postgres:5432/constructos"
DATABASE_SSL="false"
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS"
SEED_CEO_PIN="CHANGE_ME"
SEED_ACCOUNTANT_PIN="CHANGE_ME"
SEED_SITE_MANAGER_PIN="CHANGE_ME"
SEED_AUDITOR_PIN="CHANGE_ME"
SEED_EMPLOYEE_PIN="CHANGE_ME"
